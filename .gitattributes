# Auto detect text files and normalize line endings
* text=auto eol=lf

# Java
*.java text
*.xml text
*.properties text
*.yml text
*.yaml text

# Frontend
*.js text
*.ts text
*.tsx text
*.jsx text
*.vue text
*.css text
*.scss text
*.less text
*.html text
*.json text

# Shell scripts
*.sh text eol=lf

# Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text
*.txt text

# Docker
Dockerfile text
docker-compose*.yml text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.jar binary
*.war binary
*.class binary
*.zip binary
*.tar.gz binary
*.tgz binary
